async function saveZona() {
    const nama     = document.getElementById('zona_nama').value.trim();
    const jenis    = document.getElementById('zona_jenis').value;
    const parentId = document.getElementById('zona_parent').value || null;
    const koordRaw = document.getElementById('zona_koordinat').value.trim();

    if (!koordRaw) {
        alert('Koordinat kosong!\nGunakan tombol ✏️ Gambar Zona terlebih dahulu.');
        return;
    }

    let koord;
    try {
        koord = JSON.parse(koordRaw);
    } catch (e) {
        alert('Format koordinat tidak valid.');
        return;
    }

    if (!Array.isArray(koord) || koord.length < 3) {
        alert('Minimal 3 titik koordinat untuk zona.');
        return;
    }

    try {
        const zona  = await loadData('zona');
        const entry = { id: 'z' + Date.now(), nama: nama || 'Zona Baru', jenis, parentId, koordinat: koord };
        zona.push(entry);
        await saveData('zona', zona);
        await addHistory('CREATE', 'Zona', { nama: entry.nama });
        document.getElementById('zona_nama').value      = '';
        document.getElementById('zona_koordinat').value = '';
        alert('✅ Zona berhasil disimpan!');
        renderMap();
    } catch (err) {
        alert('Gagal menyimpan: ' + err.message);
    }
}

async function deleteZona(id) {
    if (!confirm('Hapus zona ini (termasuk zona anak)?')) return;
    const zona = (await loadData('zona')).filter(z => z.id !== id && z.parentId !== id);
    await saveData('zona', zona);
    await addHistory('DELETE', 'Zona', { id });
    renderMap();
}

async function editZona(id) {
    const z = (await loadData('zona')).find(x => x.id === id);
    if (!z) return;
    document.getElementById('zona_nama').value      = z.nama;
    document.getElementById('zona_jenis').value     = z.jenis;
    document.getElementById('zona_parent').value    = z.parentId || '';
    document.getElementById('zona_koordinat').value = JSON.stringify(z.koordinat);
    switchTab('zona');
}
